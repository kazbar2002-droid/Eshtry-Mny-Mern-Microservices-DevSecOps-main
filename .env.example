# MongoDB Atlas username
MONGO_USERNAME=your_mongodb_username

# MongoDB Atlas password
MONGO_PASSWORD=your_mongodb_password

# MongoDB Atlas cluster hostname (e.g., cluster0.xxxxx.mongodb.net)
MONGO_CLUSTER=your_mongodb_cluster

# MongoDB database name
MONGO_DBNAME=eshtry_mny

# JWT signing secret (any random string for local dev)
ACCESS_TOKEN=your_random_jwt_secret
